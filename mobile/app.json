{
  "expo": {
    "name": "ConvoReal",
    "slug": "convoreal",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "convoreal",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.convoreal.app",
      "associatedDomains": [
        "applinks:convoreal.com",
        "applinks:www.convoreal.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.convoreal.app",
      "allowBackup": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A1F16"
      },
      "predictiveBackGestureEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "convoreal.com"
            },
            {
              "scheme": "https",
              "host": "www.convoreal.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ConvoReal uses your location to find property listings near you."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#0A1F16",
          "dark": {
            "backgroundColor": "#0A1F16"
          }
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "ConvoReal imports contacts you choose into your CRM."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ConvoReal adds photos you choose to your property listings.",
          "cameraPermission": "ConvoReal uses the camera to add photos to your property listings."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0A1F16"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "35ac40bb-d476-4b1f-ae5f-139b38e409dd"
      }
    },
    "owner": "praneethpvrealtys-team",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/35ac40bb-d476-4b1f-ae5f-139b38e409dd"
    }
  }
}
