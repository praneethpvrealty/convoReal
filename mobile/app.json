{
  "expo": {
    "name": "ConvoReal",
    "slug": "convoreal",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "convoreal",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.convoreal.app",
      "associatedDomains": [
        "applinks:convoreal.com",
        "applinks:www.convoreal.com"
      ]
    },
    "android": {
      "package": "com.convoreal.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1A4D42"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "convoreal.com" },
            { "scheme": "https", "host": "www.convoreal.com" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ConvoReal uses your location to find property listings near you."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#1A4D42",
          "dark": {
            "backgroundColor": "#0F1513"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
