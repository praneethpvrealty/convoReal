# Copy to .env (git-ignored) and fill in. All EXPO_PUBLIC_* values are
# embedded in the app bundle — never put secrets here.

# MUST be the exact Supabase project the deployed web app uses
# (Settings → API in the dashboard). If they differ — e.g. after a DB
# migration to a new project/region — direct reads still work but every
# /api/* call fails "Unauthorized", because the server validates your
# token against ITS project. Verify with More → Connection check in the
# app after any migration, and restart with `npx expo start -c` after
# changing these (they're baked in at bundle time).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Deployed Next.js web app — all /api/* calls and media proxying go here.
# For local development against `npm run dev` on your machine, use your
# machine's LAN IP (the phone must reach it), e.g. http://192.168.1.10:3000
EXPO_PUBLIC_API_BASE_URL=https://your-convoreal-deployment.vercel.app
