# Copy to .env (git-ignored) and fill in. All EXPO_PUBLIC_* values are
# embedded in the app bundle — never put secrets here.

# Same Supabase project as the web app (Settings → API in the dashboard).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Deployed Next.js web app — all /api/* calls and media proxying go here.
# For local development against `npm run dev` on your machine, use your
# machine's LAN IP (the phone must reach it), e.g. http://192.168.1.10:3000
EXPO_PUBLIC_API_BASE_URL=https://your-convoreal-deployment.vercel.app
